{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "git branch": "allow",
          "git branch --show-current": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git rev-parse --abbrev-ref @{upstream}": "allow",
          "git rev-parse --abbrev-ref HEAD": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "ls": "allow",
          "ls *": "allow",
          "pwd": "allow"
        },
        "edit": "ask"
      }
    }
  },
  "autoupdate": true,
  "model": "openai/gpt-5.4",
  "provider": {
    "ollama": {
      "models": {
        "gemma4:31b": {
          "_launch": true,
          "name": "gemma4:31b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
